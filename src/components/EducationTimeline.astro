---
import { Image } from 'astro:assets';

interface Education {
  institution: string;
  degree: string;
  field: string;
  year: string;
  logo: ImageMetadata;
}

interface Props {
  items: Education[];
}

const { items } = Astro.props;
---

<div class="grid grid-cols-4 gap-4">
  {items.map((edu, index) => (
    <div 
      class="edu-block group relative p-5 rounded-xl border border-border bg-elevated/50 hover:bg-elevated hover:border-green/50 transition-all duration-300 cursor-default overflow-hidden"
      style={`animation-delay: ${index * 100}ms`}
    >
      <!-- Hover glow -->
      <div class="absolute inset-0 bg-gradient-to-br from-green/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
      
      <!-- Top row: Logo + Year -->
      <div class="relative flex items-center justify-between mb-4">
        <div class="w-10 h-10 rounded-lg bg-subtle border border-border group-hover:border-green/50 flex items-center justify-center p-1.5 transition-all group-hover:scale-110 duration-300">
          <Image src={edu.logo} alt={edu.institution} class="w-full h-full object-contain" />
        </div>
        <span class="px-2.5 py-1 rounded-full bg-green/10 text-green text-xs font-mono group-hover:bg-green/20 transition-colors">{edu.year}</span>
      </div>
      
      <!-- Content -->
      <div class="relative">
        <h3 class="text-sm font-semibold text-foreground group-hover:text-green transition-colors">{edu.degree}</h3>
        <p class="text-xs text-secondary mt-1">{edu.field}</p>
        <p class="text-xs text-text-muted mt-0.5">{edu.institution}</p>
      </div>
      
      <!-- Bottom line accent -->
      <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-transparent via-green/50 to-transparent scale-x-0 group-hover:scale-x-100 transition-transform duration-300"></div>
    </div>
  ))}
</div>

<style>
  .edu-block {
    opacity: 0;
    animation: slideUp 0.5s ease-out forwards;
  }
  
  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
