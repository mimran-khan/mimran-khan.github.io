---
import { Image } from 'astro:assets';

interface Props {
  institution: string;
  degree: string;
  field: string;
  year: string;
  logo: ImageMetadata;
}

const { institution, degree, field, year, logo } = Astro.props;
---

<article class="card group flex items-start gap-4">
  <div class="shrink-0 w-14 h-14 rounded-lg bg-subtle border border-border flex items-center justify-center overflow-hidden p-2">
    <Image 
      src={logo} 
      alt={institution}
      class="w-full h-full object-contain filter brightness-90 group-hover:brightness-100 transition-all"
    />
  </div>
  
  <div class="flex-1 min-w-0">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
      <div>
        <h3 class="text-body text-foreground font-medium group-hover:text-green transition-colors">
          {degree}
        </h3>
        <p class="text-small text-secondary">{field}</p>
        <p class="text-small text-secondary">{institution}</p>
      </div>
      <span class="text-small font-mono text-green shrink-0">{year}</span>
    </div>
  </div>
</article>
