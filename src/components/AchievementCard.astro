---
interface Props {
  title: string;
  description: string;
  year: string;
}

const { title, description, year } = Astro.props;
---

<div class="flex items-start gap-4 py-3 border-b border-border last:border-0 group">
  <span class="text-small font-mono text-green shrink-0 w-16 whitespace-nowrap">{year}</span>
  <div class="min-w-0">
    <h3 class="text-body text-foreground font-medium group-hover:text-green transition-colors">
      {title}
    </h3>
    <p class="text-small text-secondary">
      {description}
    </p>
  </div>
</div>
