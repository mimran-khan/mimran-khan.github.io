---
import { Image } from 'astro:assets';

import technoversAward from '../assets/images/speaking/technoverse-award.png';
import technoverseSpeakers from '../assets/images/speaking/technoverse-speakers.png';
import technoverseKeynote from '../assets/images/speaking/technoverse-keynote.png';
---

<div class="space-y-6">
  <!-- Featured Talk -->
  <div class="group relative rounded-xl border border-border bg-elevated overflow-hidden">
    <div class="grid md:grid-cols-2 gap-0">
      <!-- Image gallery -->
      <div class="relative aspect-video md:aspect-auto">
        <div class="grid grid-cols-2 h-full">
          <div class="relative overflow-hidden">
            <Image 
              src={technoversAward} 
              alt="Receiving award at Technoverse"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="grid grid-rows-2">
            <div class="relative overflow-hidden">
              <Image 
                src={technoverseKeynote} 
                alt="Keynote presentation"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="relative overflow-hidden">
              <Image 
                src={technoverseSpeakers} 
                alt="Technoverse speakers panel"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          </div>
        </div>
      </div>
      
      <!-- Content -->
      <div class="p-6 md:p-8 flex flex-col justify-center">
        <div class="flex items-center gap-3 mb-4">
          <span class="px-3 py-1 rounded-full bg-green/10 text-green text-xs font-mono">Jan 2026</span>
          <span class="px-3 py-1 rounded-full bg-cyan/10 text-cyan text-xs">Keynote</span>
        </div>
        
        <h3 class="text-xl font-semibold text-foreground group-hover:text-green transition-colors mb-3">
          Technoverse: AI Conclave 2026
        </h3>
        
        <p class="text-sm text-secondary mb-4">
          MIT ADT University, Pune
        </p>
        
        <h4 class="text-base text-foreground font-medium mb-2">
          "Decoding Ancient Algorithms"
        </h4>
        
        <p class="text-sm text-secondary leading-relaxed">
          Keynote on the intersection of Generative AI and Indian Knowledge Systems. 
          Explored how low-resource languages like Sanskrit can influence modern AI design 
          and help build more efficient, contextually aligned language models.
        </p>
        
        <div class="flex flex-wrap gap-2 mt-5">
          <span class="px-2 py-1 rounded bg-subtle text-xs text-secondary">Generative AI</span>
          <span class="px-2 py-1 rounded bg-subtle text-xs text-secondary">LLMs</span>
          <span class="px-2 py-1 rounded bg-subtle text-xs text-secondary">Sanskrit</span>
          <span class="px-2 py-1 rounded bg-subtle text-xs text-secondary">NLP</span>
        </div>
      </div>
    </div>
  </div>
</div>
