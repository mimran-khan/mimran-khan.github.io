---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import NextEpisodeTeaser from '../../../components/NextEpisodeTeaser.astro';
---

<BaseLayout
  title="Antidoom: One LoRA to Kill Your Model's Doom Loops | Demystifying AI in 5 Minutes"
  description="Liquid AI open-sourced Antidoom: find the exact token that starts a repetition loop, train a LoRA adapter with FTPO, drop Qwen3.5-4B looping from 22.9% to 1%. Full pipeline, a few hours."
  image="/og-series-ep06-antidoom.png"
  keywords="Antidoom, Doom Loops, FTPO, Final Token Preference Optimization, LoRA, Liquid AI, Repetition Loops, Reasoning Models, Qwen3.5, LFM2.5, Open Source"
  publishedDate="2026-07-18"
>

  <style>
    .stat-card {
      transition: all 0.3s ease;
    }
    .stat-card:hover {
      transform: scale(1.02);
      box-shadow: 0 0 20px rgba(34, 211, 238, 0.1);
    }
    .feature-card {
      transition: all 0.3s ease;
    }
    .feature-card:hover {
      transform: translateY(-2px);
    }
  </style>

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-gradient-to-b from-cyan/[0.04] via-background to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,211,238,0.06)_0%,transparent_60%)]"></div>

    <div class="relative container-main max-w-4xl pt-20 pb-10">
      <a href="/series/demystifying-ai" class="inline-flex items-center gap-2 text-xs text-secondary hover:text-green transition-colors mb-8 font-mono">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        cd ~/series/demystifying-ai
      </a>

      <div class="rounded-xl overflow-hidden border border-border mb-8">
        <img src="/series/ep06-antidoom.png" alt="Antidoom - One LoRA to Kill Your Model's Doom Loops" class="w-full h-auto block" />
      </div>

      <div class="flex flex-wrap items-center gap-2 md:gap-3 mb-4">
        <span class="flex items-center gap-1.5 text-[10px] text-cyan font-mono bg-cyan/5 border border-cyan/20 px-2 py-1 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
          EP 06
        </span>
        <a href="https://github.com/Liquid4All/antidoom" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2 py-1 text-[10px] font-mono bg-cyan/10 border border-cyan/20 text-cyan rounded-full hover:bg-cyan/20 hover:border-cyan/40 transition-colors">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          GitHub
          <svg class="w-2.5 h-2.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        <span class="text-[10px] text-secondary font-mono">Jul 18, 2026</span>
        <span class="text-[10px] text-secondary font-mono">5 min</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-foreground leading-tight mb-3">
        Antidoom: One LoRA to Kill Your Model's Doom Loops
      </h1>
      <p class="text-sm md:text-base text-secondary max-w-2xl mb-5">
        Liquid AI found the exact token where repetition starts. One LoRA adapter, trained in hours, drops Qwen3.5-4B looping from 22.9% to 1%. Full pipeline open-sourced.
      </p>

      <ShareButtons title="Antidoom: One LoRA to Kill Your Model's Doom Loops" url="/series/demystifying-ai/antidoom" />
    </div>
  </section>

  <!-- Article Body -->
  <article class="container-main max-w-4xl py-8 md:py-10 overflow-hidden">

    <!-- TL;DR -->
    <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 md:p-6 mb-8 md:mb-10 max-w-3xl">
      <span class="text-xs font-mono text-cyan font-bold">// TL;DR</span>
      <p class="text-sm text-foreground/90 leading-relaxed mt-3 mb-0">
        Doom loops kill reasoning models: the model emits a span, then repeats it until the context window is exhausted. Antidoom identifies the <strong>first token</strong> that starts the loop, trains a LoRA adapter to prefer coherent alternatives at that exact position using <strong>FTPO</strong>, and leaves the rest of the distribution untouched. Qwen3.5-4B: <strong>22.9% to 1%</strong>. Eval scores improved. Full pipeline runs in hours.
      </p>
    </div>

    <!-- ==================== SECTION 1: The Problem ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-cyan font-mono text-sm">#</span> The Problem
      </h2>

      <p class="text-sm text-secondary leading-relaxed mb-6">
        A reasoning model gets a hard math problem. It starts thinking. Then it emits a phrase. Then the same phrase again. And again. <strong>Until the context window is exhausted.</strong> That is a doom loop.
      </p>

      <!-- Before/After comparison -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="rounded-xl border border-red-500/30 bg-red-500/[0.03] p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <span class="text-[10px] font-mono text-red-400 font-bold">DOOM LOOP</span>
          </div>
          <div class="rounded-lg bg-[#161b22] p-3 overflow-x-auto">
            <pre class="text-[10px] font-mono leading-relaxed"><span class="text-secondary">Let me reconsider...</span>
<span class="text-red-400">Let me reconsider...</span>
<span class="text-red-400">Let me reconsider...</span>
<span class="text-red-400">Let me reconsider...</span>
<span class="text-red-400">Let me reconsider...</span>
<span class="text-red-400/50">... (2048 more tokens)</span>
<span class="text-red-400/30">[context exhausted]</span></pre>
          </div>
          <p class="text-[10px] text-secondary mt-2 mb-0">Model stuck in infinite repetition. No answer produced.</p>
        </div>

        <div class="rounded-xl border border-green/30 bg-green/[0.03] p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-2 h-2 rounded-full bg-green"></span>
            <span class="text-[10px] font-mono text-green font-bold">AFTER ANTIDOOM</span>
          </div>
          <div class="rounded-lg bg-[#161b22] p-3 overflow-x-auto">
            <pre class="text-[10px] font-mono leading-relaxed"><span class="text-secondary">Let me reconsider...</span>
<span class="text-green">Actually, I should try a</span>
<span class="text-green">different approach. The key</span>
<span class="text-green">insight is that x = 2pi...</span>
<span class="text-green">Therefore the answer is 42.</span>
<span class="text-green/50">[coherent completion]</span></pre>
          </div>
          <p class="text-[10px] text-secondary mt-2 mb-0">Model recovers at the exact loop-start token. Answer produced.</p>
        </div>
      </div>

      <!-- Why it matters -->
      <div class="grid grid-cols-3 gap-3">
        <div class="stat-card rounded-xl border border-red-500/20 bg-red-500/[0.03] p-4 text-center">
          <div class="text-2xl md:text-3xl font-bold text-red-400">22.9%</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Qwen3.5-4B loop rate</div>
        </div>
        <div class="stat-card rounded-xl border border-red-500/20 bg-red-500/[0.03] p-4 text-center">
          <div class="text-2xl md:text-3xl font-bold text-red-400">10.2%</div>
          <div class="text-[10px] text-secondary font-mono mt-1">LFM2.5-2.6B loop rate</div>
        </div>
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="text-lg md:text-xl font-bold text-cyan">Small models</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Most vulnerable</div>
        </div>
      </div>
    </div>

    <!-- ==================== SECTION 2: How FTPO Works ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-cyan font-mono text-sm">#</span> How FTPO Works
      </h2>

      <p class="text-sm text-secondary leading-relaxed mb-6">
        Most anti-repetition methods retrain on full gold answers. Antidoom does something narrower: <strong>fix exactly one token.</strong>
      </p>

      <!-- 4-step pipeline -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="w-10 h-10 rounded-full bg-cyan/20 border-2 border-cyan flex items-center justify-center mx-auto mb-2">
            <span class="text-cyan text-[10px] font-mono font-bold">01</span>
          </div>
          <span class="text-xs font-mono text-cyan font-bold block">Generate</span>
          <span class="text-[10px] text-secondary mt-1 block">Sample completions on hard prompts</span>
        </div>
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="w-10 h-10 rounded-full bg-cyan/20 border-2 border-cyan flex items-center justify-center mx-auto mb-2">
            <span class="text-cyan text-[10px] font-mono font-bold">02</span>
          </div>
          <span class="text-xs font-mono text-cyan font-bold block">Detect</span>
          <span class="text-[10px] text-secondary mt-1 block">Find the first token of each repeated span</span>
        </div>
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="w-10 h-10 rounded-full bg-cyan/20 border-2 border-cyan flex items-center justify-center mx-auto mb-2">
            <span class="text-cyan text-[10px] font-mono font-bold">03</span>
          </div>
          <span class="text-xs font-mono text-cyan font-bold block">Train</span>
          <span class="text-[10px] text-secondary mt-1 block">FTPO on chosen/rejected pairs at that token</span>
        </div>
        <div class="rounded-xl border border-green/20 bg-green/[0.03] p-4 text-center">
          <div class="w-10 h-10 rounded-full bg-green/20 border-2 border-green flex items-center justify-center mx-auto mb-2">
            <span class="text-green text-[10px] font-mono font-bold">04</span>
          </div>
          <span class="text-xs font-mono text-green font-bold block">Merge</span>
          <span class="text-[10px] text-secondary mt-1 block">LoRA adapter merged into base model</span>
        </div>
      </div>

      <!-- Token-level diagram -->
      <div class="rounded-xl border border-cyan/20 bg-[#161b22] p-4 md:p-5 mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-mono text-cyan">TOKEN-LEVEL TARGETING</span>
        </div>
        <div class="space-y-2">
          <div class="flex items-center gap-1 flex-wrap">
            <span class="text-[10px] font-mono text-secondary/60 w-16 shrink-0">context:</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">Let</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">me</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">think</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">about</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">this</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-secondary/10 text-secondary">...</span>
          </div>
          <div class="flex items-center gap-1 flex-wrap">
            <span class="text-[10px] font-mono text-red-400/60 w-16 shrink-0">rejected:</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-red-500/20 text-red-400 border border-red-500/30">Let</span>
            <span class="text-[9px] text-secondary/40">(starts the loop)</span>
          </div>
          <div class="flex items-center gap-1 flex-wrap">
            <span class="text-[10px] font-mono text-green/60 w-16 shrink-0">chosen:</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-green/20 text-green border border-green/30">Actually</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-green/20 text-green border border-green/30">Wait</span>
            <span class="px-1.5 py-0.5 text-[9px] font-mono rounded bg-green/20 text-green border border-green/30">So</span>
            <span class="text-[9px] text-secondary/40">(coherent alternatives)</span>
          </div>
        </div>
        <p class="text-[10px] text-secondary mt-3 mb-0">FTPO spreads probability across multiple coherent alternatives. It does not pick one replacement.</p>
      </div>

      <!-- Key design choices -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
        <div class="rounded-xl border border-cyan/20 bg-elevated p-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-6 h-6 rounded-md bg-cyan/10 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </span>
            <span class="text-xs font-semibold text-foreground">High LoRA rank</span>
          </div>
          <p class="text-[11px] text-secondary">Rank 128-256 produces best results. Higher learnability with less degradation than low-rank alternatives.</p>
        </div>
        <div class="rounded-xl border border-cyan/20 bg-elevated p-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-6 h-6 rounded-md bg-cyan/10 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </span>
            <span class="text-xs font-semibold text-foreground">Minimal collateral damage</span>
          </div>
          <p class="text-[11px] text-secondary">Trains on all attention + MLP projections + lm_head. One epoch. Learning rate 4e-6 to 2e-5.</p>
        </div>
      </div>
    </div>

    <!-- ==================== SECTION 3: The Numbers ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-cyan font-mono text-sm">#</span> The Numbers
      </h2>

      <p class="text-xs text-secondary mb-4">2 models tested &middot; Loop rate and eval scores measured independently</p>

      <!-- Before/After stat cards -->
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4">
          <div class="text-[10px] text-secondary font-mono mb-2">Qwen3.5-4B</div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-red-400 font-mono text-sm line-through">22.9%</span>
            <span class="text-secondary">&rarr;</span>
            <span class="text-green font-mono text-2xl font-bold">1%</span>
          </div>
          <div class="text-[10px] text-green font-mono">doom loop rate</div>
        </div>
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4">
          <div class="text-[10px] text-secondary font-mono mb-2">LFM2.5-2.6B</div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-red-400 font-mono text-sm line-through">10.2%</span>
            <span class="text-secondary">&rarr;</span>
            <span class="text-green font-mono text-2xl font-bold">1.4%</span>
          </div>
          <div class="text-[10px] text-green font-mono">doom loop rate</div>
        </div>
      </div>

      <!-- Key insight: evals improved -->
      <div class="rounded-xl border border-green/20 bg-green/[0.03] p-4 md:p-5 mb-6">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[10px] font-mono text-green font-bold">KEY RESULT</span>
          <span class="text-xs font-semibold text-foreground">Eval scores went UP, not down</span>
        </div>
        <p class="text-sm text-foreground/90 leading-relaxed mb-0">
          This is the critical finding. Antidoom does not trade capability for stability. <strong>Eval scores improved across the board</strong> after training. The improvement is attributable entirely to the reduction in looping: the model was already capable of producing the right answer, it was just getting stuck before reaching it.
        </p>
      </div>

      <!-- Training cost -->
      <div class="grid grid-cols-3 gap-3">
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="text-xl md:text-2xl font-bold text-cyan">1</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Epoch</div>
        </div>
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="text-xl md:text-2xl font-bold text-cyan">128-256</div>
          <div class="text-[10px] text-secondary font-mono mt-1">LoRA Rank</div>
        </div>
        <div class="stat-card rounded-xl border border-cyan/20 bg-cyan/[0.03] p-4 text-center">
          <div class="text-xl md:text-2xl font-bold text-cyan">Hours</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Total Training Time</div>
        </div>
      </div>
    </div>

    <!-- ==================== SECTION 4: Try It ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-cyan font-mono text-sm">#</span> Try It
      </h2>

      <p class="text-sm text-secondary leading-relaxed mb-4">
        The full pipeline is one command. Edit <code class="text-[10px] bg-cyan/10 px-1 rounded">configs/default.yaml</code>, set your model, run.
      </p>

      <div class="rounded-xl border border-border bg-[#161b22] p-4 md:p-5 overflow-x-auto mb-4">
        <pre class="text-xs font-mono leading-relaxed"><span class="text-cyan font-bold">git clone</span> <span class="text-foreground">https://github.com/Liquid4All/antidoom.git</span>
<span class="text-cyan font-bold">cd</span> <span class="text-foreground">antidoom</span>
<span class="text-cyan font-bold">pip install</span> <span class="text-foreground">-e .</span>

<span class="text-secondary"># Edit configs/default.yaml</span>
<span class="text-secondary"># Set model_name to the checkpoint you want to fix</span>
<span class="text-secondary"># Default prompts: LiquidAI/antidoom-mix-v1.0</span>

<span class="text-cyan font-bold">python -m antidoom</span>
<span class="text-secondary"># Generates FTPO pairs -> Trains LoRA -> Merges adapter</span></pre>
      </div>

      <!-- What happens under the hood -->
      <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-3 text-center">
          <span class="text-xs font-mono text-cyan font-bold block mb-1">One-shot</span>
          <span class="text-[10px] text-secondary">Generate, detect, train, merge in one run</span>
        </div>
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-3 text-center">
          <span class="text-xs font-mono text-cyan font-bold block mb-1">Idempotent</span>
          <span class="text-[10px] text-secondary">Skips generation if FTPO pairs already exist</span>
        </div>
        <div class="rounded-xl border border-cyan/20 bg-cyan/[0.03] p-3 text-center">
          <span class="text-xs font-mono text-cyan font-bold block mb-1">Early stopping</span>
          <span class="text-[10px] text-secondary">Prevents over-training that degrades quality</span>
        </div>
      </div>

      <!-- Source links -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <a href="https://github.com/Liquid4All/antidoom" target="_blank" rel="noopener noreferrer" class="feature-card rounded-xl border border-cyan/20 bg-elevated p-3 text-center hover:border-cyan/40 transition-colors block">
          <span class="text-[10px] font-mono text-cyan font-bold block mb-1">GitHub</span>
          <span class="text-[9px] text-secondary">Full pipeline</span>
        </a>
        <a href="https://www.liquid.ai/blog/antidoom" target="_blank" rel="noopener noreferrer" class="feature-card rounded-xl border border-cyan/20 bg-elevated p-3 text-center hover:border-cyan/40 transition-colors block">
          <span class="text-[10px] font-mono text-cyan font-bold block mb-1">Blog</span>
          <span class="text-[9px] text-secondary">Liquid AI</span>
        </a>
        <a href="https://huggingface.co/datasets/LiquidAI/antidoom-mix-v1.0" target="_blank" rel="noopener noreferrer" class="feature-card rounded-xl border border-green/20 bg-elevated p-3 text-center hover:border-green/40 transition-colors block">
          <span class="text-[10px] font-mono text-green font-bold block mb-1">Dataset</span>
          <span class="text-[9px] text-secondary">antidoom-mix-v1.0</span>
        </a>
        <a href="https://liquid.ai/" target="_blank" rel="noopener noreferrer" class="feature-card rounded-xl border border-cyan/20 bg-elevated p-3 text-center hover:border-cyan/40 transition-colors block">
          <span class="text-[10px] font-mono text-cyan font-bold block mb-1">Liquid AI</span>
          <span class="text-[9px] text-secondary">Team page</span>
        </a>
      </div>
    </div>

    <!-- Bottom Line -->
