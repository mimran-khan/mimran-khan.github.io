---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareButtons from '../../../components/ShareButtons.astro';
import NextEpisodeTeaser from '../../../components/NextEpisodeTeaser.astro';
---

<BaseLayout
  title="SkillOpt: Your Agent's Skills Are Trainable Parameters | Demystifying AI in 5 Minutes"
  description="Microsoft's SkillOpt treats a skill file as a trainable parameter of a frozen agent. +23.5 points on GPT-5.5 across 6 benchmarks without changing model weights."
  image="/og-series-ep05-skillopt.png"
  keywords="SkillOpt, Agent Skills, Trainable Parameters, Microsoft Research, Skill Optimization, best_skill.md, Codex, Claude Code, Frozen Agent, Text Optimization"
  publishedDate="2026-07-15"
  articleSection="Demystifying AI"
  articleTags={["SkillOpt", "Agent Skills", "Microsoft Research", "Prompt Optimization", "Claude Code"]}
>

  <style>
    .stat-card {
      transition: all 0.3s ease;
    }
    .stat-card:hover {
      transform: scale(1.02);
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.1);
    }
    .feature-card {
      transition: all 0.3s ease;
    }
    .feature-card:hover {
      transform: translateY(-2px);
    }
  </style>

  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-gradient-to-b from-violet-500/[0.04] via-background to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(139,92,246,0.06)_0%,transparent_60%)]"></div>

    <div class="relative container-main max-w-4xl pt-20 pb-10">
      <a href="/series/demystifying-ai" class="inline-flex items-center gap-2 text-xs text-secondary hover:text-green transition-colors mb-8 font-mono">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        cd ~/series/demystifying-ai
      </a>

      <div class="rounded-xl overflow-hidden border border-border mb-8">
        <img src="/series/ep05-skillopt.png" alt="SkillOpt - Your Agent's Skills Are Trainable Parameters" class="w-full h-auto block" />
      </div>

      <div class="flex flex-wrap items-center gap-2 md:gap-3 mb-4">
        <span class="flex items-center gap-1.5 text-[10px] text-violet-400 font-mono bg-violet-500/5 border border-violet-500/20 px-2 py-1 rounded-full">
          <span class="w-1.5 h-1.5 rounded-full bg-violet-400 animate-pulse"></span>
          EP 05
        </span>
        <a href="https://arxiv.org/abs/2605.23904" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2 py-1 text-[10px] font-mono bg-violet-500/10 border border-violet-500/20 text-violet-400 rounded-full hover:bg-violet-500/20 hover:border-violet-500/40 transition-colors">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm-.5 3.5a1 1 0 011 0l6.5 3.75a1 1 0 01.5.866v7.5a1 1 0 01-.5.866l-6.5 3.75a1 1 0 01-1 0l-6.5-3.75a1 1 0 01-.5-.866v-7.5a1 1 0 01.5-.866l6.5-3.75z"/></svg>
          arXiv
          <svg class="w-2.5 h-2.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        <span class="text-[10px] text-secondary font-mono">Jul 15, 2026</span>
        <span class="text-[10px] text-secondary font-mono">5 min</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-foreground leading-tight mb-3">
        SkillOpt: Your Agent's Skills Are Trainable Parameters
      </h1>
      <p class="text-sm md:text-base text-secondary max-w-2xl mb-5">
        Microsoft trained agent skills like neural network weights. +23 points on GPT-5.5 without changing a single model parameter.
      </p>

      <ShareButtons title="SkillOpt: Your Agent's Skills Are Trainable Parameters" url="/series/demystifying-ai/skillopt" />
    </div>
  </section>

  <!-- Article Body -->
  <article class="container-main max-w-4xl py-8 md:py-10 overflow-hidden">

    <!-- TL;DR -->
    <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4 md:p-6 mb-8 md:mb-10 max-w-3xl">
      <span class="text-xs font-mono text-violet-400 font-bold">// TL;DR</span>
      <p class="text-sm text-foreground/90 leading-relaxed mt-3 mb-0">
        SkillOpt treats a plain-text skill file as the trainable parameter of a frozen agent. A separate optimizer model proposes bounded edits; only improvements survive. <strong>52/52</strong> evaluation cells: best or tied. GPT-5.5: <strong>+23.5 points</strong>. Deployed artifact: one readable markdown file. <code class="text-[10px] bg-violet-500/10 px-1 rounded">pip install skillopt</code>.
      </p>
    </div>

    <!-- ==================== SECTION 1: Train Skills Like Weights ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-violet-400 font-mono text-sm">#</span> Train Skills Like Weights
      </h2>

      <!-- Side-by-side analogy -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] font-mono text-violet-400 font-bold">NEURAL NETWORK</span>
          </div>
          <div class="space-y-3">
            <div class="flex items-start gap-2">
              <span class="text-violet-400 text-xs mt-0.5">&#9654;</span>
              <div><span class="text-xs font-semibold text-foreground">Forward pass</span><br/><span class="text-[11px] text-secondary">Run model on batch</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-violet-400 text-xs mt-0.5">&#9664;</span>
              <div><span class="text-xs font-semibold text-foreground">Backward pass</span><br/><span class="text-[11px] text-secondary">Compute gradients</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-violet-400 text-xs mt-0.5">&#9881;</span>
              <div><span class="text-xs font-semibold text-foreground">Learning rate</span><br/><span class="text-[11px] text-secondary">Bounds weight update</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-violet-400 text-xs mt-0.5">&#10003;</span>
              <div><span class="text-xs font-semibold text-foreground">Validation</span><br/><span class="text-[11px] text-secondary">Early stopping on held-out set</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-violet-400 text-xs mt-0.5">&#9744;</span>
              <div><span class="text-xs font-semibold text-foreground">Artifact</span><br/><span class="text-[11px] text-secondary">model.bin (opaque)</span></div>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-green/20 bg-green/[0.03] p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[10px] font-mono text-green font-bold">SKILLOPT</span>
          </div>
          <div class="space-y-3">
            <div class="flex items-start gap-2">
              <span class="text-green text-xs mt-0.5">&#9654;</span>
              <div><span class="text-xs font-semibold text-foreground">Rollout</span><br/><span class="text-[11px] text-secondary">Frozen agent runs tasks with current skill</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green text-xs mt-0.5">&#9664;</span>
              <div><span class="text-xs font-semibold text-foreground">Reflect</span><br/><span class="text-[11px] text-secondary">Optimizer reads trajectories, distills patterns</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green text-xs mt-0.5">&#9881;</span>
              <div><span class="text-xs font-semibold text-foreground">Edit budget</span><br/><span class="text-[11px] text-secondary">Bounds text edits (add/delete/replace)</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green text-xs mt-0.5">&#10003;</span>
              <div><span class="text-xs font-semibold text-foreground">Validation gate</span><br/><span class="text-[11px] text-secondary">Accept ONLY if held-out score strictly improves</span></div>
            </div>
            <div class="flex items-start gap-2">
              <span class="text-green text-xs mt-0.5">&#9744;</span>
              <div><span class="text-xs font-semibold text-foreground">Artifact</span><br/><span class="text-[11px] text-secondary">best_skill.md (~920 tokens, readable)</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 stat cards -->
      <div class="grid grid-cols-3 gap-3">
        <div class="stat-card rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4 text-center">
          <div class="text-2xl md:text-3xl font-bold text-violet-400">52/52</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Cells Best or Tied</div>
        </div>
        <div class="stat-card rounded-xl border border-green/20 bg-green/[0.03] p-4 text-center">
          <div class="text-2xl md:text-3xl font-bold text-green">+23.5</div>
          <div class="text-[10px] text-secondary font-mono mt-1">GPT-5.5 (no weight changes)</div>
        </div>
        <div class="stat-card rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4 text-center">
          <div class="text-2xl md:text-3xl font-bold text-violet-400">~920</div>
          <div class="text-[10px] text-secondary font-mono mt-1">Tokens Median Skill</div>
        </div>
      </div>
    </div>

    <!-- ==================== SECTION 2: The Loop ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-violet-400 font-mono text-sm">#</span> The Loop
      </h2>

      <!-- 4-step pipeline -->
      <div class="flex items-start gap-0 mb-6 overflow-x-auto">
        <div class="flex flex-col items-center shrink-0 w-[22%]">
          <div class="w-10 h-10 rounded-full bg-violet-500/20 border-2 border-violet-400 flex items-center justify-center">
            <span class="text-violet-400 text-[10px] font-mono font-bold">01</span>
          </div>
          <span class="text-[9px] font-mono text-violet-400 mt-2 font-bold">Rollout</span>
          <span class="text-[8px] text-secondary text-center mt-1 max-w-[90px]">Frozen model runs 40 tasks with current skill</span>
        </div>
        <div class="flex-1 h-0.5 bg-violet-500/30 min-w-[20px] mt-5"></div>
        <div class="flex flex-col items-center shrink-0 w-[22%]">
          <div class="w-10 h-10 rounded-full bg-violet-500/20 border-2 border-violet-400 flex items-center justify-center">
            <span class="text-violet-400 text-[10px] font-mono font-bold">02</span>
          </div>
          <span class="text-[9px] font-mono text-violet-400 mt-2 font-bold">Reflect</span>
          <span class="text-[8px] text-secondary text-center mt-1 max-w-[90px]">16 workers reflect in minibatches of 8</span>
        </div>
        <div class="flex-1 h-0.5 bg-violet-500/30 min-w-[20px] mt-5"></div>
        <div class="flex flex-col items-center shrink-0 w-[22%]">
          <div class="w-10 h-10 rounded-full bg-violet-500/20 border-2 border-violet-400 flex items-center justify-center">
            <span class="text-violet-400 text-[10px] font-mono font-bold">03</span>
          </div>
          <span class="text-[9px] font-mono text-violet-400 mt-2 font-bold">Edit</span>
          <span class="text-[8px] text-secondary text-center mt-1 max-w-[90px]">add/delete/replace clipped by edit budget (4, cosine decay)</span>
        </div>
        <div class="flex-1 h-0.5 bg-green/30 min-w-[20px] mt-5"></div>
        <div class="flex flex-col items-center shrink-0 w-[22%]">
          <div class="w-10 h-10 rounded-full bg-green/20 border-2 border-green flex items-center justify-center">
            <span class="text-green text-[10px] font-mono font-bold">04</span>
          </div>
          <span class="text-[9px] font-mono text-green mt-2 font-bold">Validate</span>
          <span class="text-[8px] text-secondary text-center mt-1 max-w-[90px]">Accept only if held-out score strictly improves</span>
        </div>
      </div>

      <!-- Two-model architecture callout -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
        <div class="rounded-xl border border-violet-500/20 bg-elevated p-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-6 h-6 rounded-md bg-violet-500/10 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            </span>
            <span class="text-xs font-semibold text-foreground">Frozen target model</span>
          </div>
          <p class="text-[11px] text-secondary">Executes tasks. Never changes. GPT-5.5 down to Qwen3.5-4B.</p>
        </div>
        <div class="rounded-xl border border-violet-500/20 bg-elevated p-4">
          <div class="flex items-center gap-2 mb-1">
            <span class="w-6 h-6 rounded-md bg-violet-500/10 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </span>
            <span class="text-xs font-semibold text-foreground">Separate optimizer model</span>
          </div>
          <p class="text-[11px] text-secondary">Reads trajectories. Proposes bounded edits. Maintains rejected-edit buffer + meta skill.</p>
        </div>
      </div>

      <!-- Slow/meta update -->
      <div class="rounded-xl border border-violet-500/10 bg-violet-500/[0.02] p-4 mb-4">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[10px] font-mono text-violet-400 font-bold">EPOCH-WISE</span>
          <span class="text-xs font-semibold text-foreground">Slow update + meta skill</span>
        </div>
        <p class="text-[11px] text-secondary">After each epoch, a slow update consolidates longer-horizon lessons that single batches can't reveal. A meta skill summarizes accepted/rejected patterns into optimizer-only guidance.</p>
      </div>

      <!-- Ablation callout -->
      <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4">
        <span class="text-xs font-mono text-violet-400 font-bold">// Why each component matters</span>
        <p class="text-xs text-foreground/90 leading-relaxed mt-2 mb-0">
          Removing the rejected-edit buffer lowers scores on <strong>all 3 ablation benchmarks</strong>. Removing both the meta skill and slow update drops SpreadsheetBench from <strong>77.5 to 55.0</strong>.
        </p>
      </div>
    </div>

    <!-- ==================== SECTION 3: The Numbers ==================== -->
    <div class="max-w-3xl mb-10 md:mb-12">
      <h2 class="text-lg font-bold text-foreground mb-4 flex items-center gap-2">
        <span class="text-violet-400 font-mono text-sm">#</span> The Numbers
      </h2>

      <p class="text-xs text-secondary mb-4">6 benchmarks &middot; 7 models &middot; 3 harnesses (direct chat, Codex, Claude Code)</p>

      <!-- Row 1: GPT-5.5 headline stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="stat-card rounded-xl border border-green/20 bg-green/[0.03] p-4 text-center">
          <div class="text-[10px] text-secondary font-mono mb-1">GPT-5.5 Direct</div>
          <div class="text-xs text-secondary">58.8 &rarr;</div>
          <div class="text-xl font-bold text-green">82.3</div>
          <div class="text-[10px] text-green font-mono">+23.5</div>
        </div>
        <div class="stat-card rounded-xl border border-green/20 bg-green/[0.03] p-4 text-center">
          <div class="text-[10px] text-secondary font-mono mb-1">GPT-5.5 Codex</div>
          <div class="text-xl font-bold text-green mt-2">+24.8</div>
          <div class="text-[10px] text-green font-mono">points</div>
        </div>
        <div class="stat-card rounded-xl border border-green/20 bg-green/[0.03] p-4 text-center">
          <div class="text-[10px] text-secondary font-mono mb-1">GPT-5.5 Claude Code</div>
          <div class="text-xl font-bold text-green mt-2">+19.1</div>
          <div class="text-[10px] text-green font-mono">points</div>
        </div>
        <div class="stat-card rounded-xl border border-violet-500/20 bg-violet-500/[0.03] p-4 text-center">
          <div class="text-[10px] text-secondary font-mono mb-1">vs Oracle</div>
          <div class="text-xl font-bold text-violet-400 mt-2">+5.4</div>
          <div class="text-[10px] text-violet-400 font-mono">above best per-cell</div>
        </div>
      </div>

      <!-- Row 2: Benchmark breakdown (desktop table) -->
      <div class="hidden md:block overflow-hidden rounded-xl border border-border mb-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-elevated">
              <th class="text-left p-3 text-xs font-mono text-secondary">Benchmark</th>
              <th class="text-center p-3 text-xs font-mono text-secondary">No Skill</th>
              <th class="text-center p-3 text-xs font-mono text-secondary">SkillOpt</th>
              <th class="text-center p-3 text-xs font-mono text-secondary">Gain</th>
              <th class="text-center p-3 text-xs font-mono text-secondary">Note</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr class="bg-violet-500/[0.02]">
              <td class="p-3 font-semibold text-foreground">SpreadsheetBench</td>
              <td class="p-3 text-center text-secondary">41.8</td>
              <td class="p-3 text-center font-bold text-green">80.7</td>
              <td class="p-3 text-center text-green">+38.9</td>
              <td class="p-3 text-center text-[10px] text-secondary"></td>
            </tr>
            <tr>
              <td class="p-3 font-semibold text-foreground">OfficeQA</td>
              <td class="p-3 text-center text-secondary">33.1</td>
              <td class="p-3 text-center font-bold text-green">72.1</td>
              <td class="p-3 text-center text-green">+39.0</td>
              <td class="p-3 text-center text-[10px] text-violet-400">1 edit</td>
            </tr>
            <tr class="bg-violet-500/[0.02]">
              <td class="p-3 font-semibold text-foreground">LiveMathBench</td>
              <td class="p-3 text-center text-secondary">37.6</td>
              <td class="p-3 text-center font-bold text-green">66.9</td>
              <td class="p-3 text-center text-green">+29.3</td>
              <td class="p-3 text-center text-[10px] text-secondary"></td>
            </tr>
            <tr>
              <td class="p-3 text-foreground/80">SearchQA</td>
              <td class="p-3 text-center text-secondary">73.3</td>
              <td class="p-3 text-center text-green">88.1</td>
              <td class="p-3 text-center text-green">+14.8</td>
              <td class="p-3 text-center text-[10px] text-secondary"></td>
            </tr>
            <tr class="bg-violet-500/[0.02]">
              <td class="p-3 text-foreground/80">DocVQA</td>
              <td class="p-3 text-center text-secondary">70.1</td>
              <td class="p-3 text-center text-green">82.1</td>
              <td class="p-3 text-center text-green">+12.0</td>
              <td class="p-3 text-center text-[10px] text-secondary"></td>
            </tr>
            <tr>
              <td class="p-3 text-foreground/80">ALFWorld</td>
              <td class="p-3 text-center text-secondary">96.3</td>
              <td class="p-3 text-center text-green">98.1</td>
              <td class="p-3 text-center text-green">+1.8</td>
              <td class="p-3 text-center text-[10px] text-secondary">near ceiling</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Row 2: Benchmark breakdown (mobile cards) -->
      <div class="md:hidden space-y-3 mb-4">
        <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.02] p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="font-semibold text-foreground text-sm">SpreadsheetBench</span>
            <span class="text-green font-mono text-xs font-bold">+38.9</span>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center text-[10px] font-mono">
            <div><span class="text-secondary block">41.8</span><span class="text-secondary">before</span></div>
            <div><span class="text-green font-bold block">80.7</span><span class="text-secondary">after</span></div>
          </div>
        </div>
        <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.02] p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="font-semibold text-foreground text-sm">OfficeQA</span>
            <span class="text-green font-mono text-xs font-bold">+39.0 (1 edit)</span>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center text-[10px] font-mono">
            <div><span class="text-secondary block">33.1</span><span class="text-secondary">before</span></div>
            <div><span class="text-green font-bold block">72.1</span><span class="text-secondary">after</span></div>
          </div>
        </div>
        <div class="rounded-xl border border-violet-500/20 bg-violet-500/[0.02] p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="font-semibold text-foreground text-sm">LiveMathBench</span>
            <span class="text-green font-mono text-xs font-bold">+29.3</span>
          </div>
          <div class="grid grid-cols-2 gap-2 text-center text-[10px] font-mono">
            <div><span class="text-secondary block">37.6</span><span class="text-secondary">before</span></div>
            <div><span class="text-green font-bold block">66.9</span><span class="text-secondary">after</span></div>
          </div>
        </div>
      </div>

      <!-- Row 3: Small models jump tiers -->
      <h3 class="text-sm font-bold text-foreground mb-3 flex items-center gap-2">
        <span class="text-violet-400 font-mono text-xs">TIER JUMP</span>
        Small models + skill &gt; larger models without
      </h3>
