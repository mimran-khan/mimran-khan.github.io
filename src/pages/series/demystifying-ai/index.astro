---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareButtons from '../../../components/ShareButtons.astro';

const episodes = [
  {
    number: 1,
    slug: 'deep-agents',
    title: 'What are LangChain Deep Agents?',
    hook: 'LangChain shipped something that makes CrewAI and AutoGen look like toys. Nobody noticed.',
    category: 'hot-topic',
    day: 'Mon',
    date: 'Jul 6',
    readTime: '5 min',
    published: true,
    image: '/series/ep01-deep-agents.png',
  },
  {
    number: 2,
    slug: 'agent-harness-grep',
    title: 'Is Grep All You Need? Agent Harness Paper',
    hook: 'Grep beats vector search inside AI agents. The results broke everyone\'s assumptions.',
    category: 'research-paper',
    day: 'Wed',
    date: 'Jul 8',
    readTime: '5 min',
    published: true,
    image: '/series/ep02-agent-harness-grep.png',
  },
  {
    number: 3,
    slug: 'longcat-2',
    title: 'LongCat-2.0: Open-Source 1M Context That Beats GPT-5.5',
    hook: 'Meituan just dropped a 1.6T parameter model with 1M token context. MIT licensed. It outperforms GPT-5.5 on SWE-bench Pro.',
    category: 'new-release',
    day: 'Sat',
    date: 'Jul 11',
    readTime: '5 min',
    published: false,
    image: '',
  },
  {
    number: 4,
    slug: 'mcp-vs-a2a',
    title: 'MCP vs A2A: The Two Protocols Running Every AI Agent',
    hook: 'One connects agents to tools, the other connects agents to each other. You need both.',
    category: 'hot-topic',
    day: 'Mon',
    date: 'Jul 13',
    readTime: '5 min',
    published: false,
    image: '',
  },
  {
    number: 5,
    slug: 'compass-agent-memory',
    title: 'COMPASS: How Agents Stay Coherent Over 200+ Steps',
    hook: 'Your AI agent forgets things after 20 steps. Here\'s how the best agents stay coherent for 200.',
    category: 'research-paper',
    day: 'Wed',
    date: 'Jul 15',
    readTime: '5 min',
    published: false,
    image: '',
  },
  {
    number: 6,
    slug: 'context-engineering',
    title: 'Context Engineering: The Skill That Replaced Prompt Engineering',
    hook: 'Prompt engineering is dead. The new skill is designing the box your AI thinks inside.',
    category: 'new-release',
    day: 'Sat',
    date: 'Jul 18',
    readTime: '5 min',
    published: false,
    image: '',
  },
];

const categoryConfig: Record<string, { label: string; color: string; bg: string; border: string; text: string }> = {
  'hot-topic': { label: 'Hot Topic', color: 'green', bg: 'bg-green/10', border: 'border-green/20', text: 'text-green' },
  'research-paper': { label: 'Research Paper', color: 'violet', bg: 'bg-violet-500/10', border: 'border-violet-500/20', text: 'text-violet-400' },
  'new-release': { label: 'New Release', color: 'cyan', bg: 'bg-cyan/10', border: 'border-cyan/20', text: 'text-cyan' },
};

const publishedEpisodes = episodes.filter(ep => ep.published).reverse();
const nextEpisode = episodes.find(ep => !ep.published);
---

<BaseLayout
  title="Demystifying AI in 5 Minutes | Series"
  description="One AI concept. Under 5 minutes. Three times a week. Breaking down cutting-edge AI research, hot topics, and new releases for builders."
  keywords="AI, Machine Learning, Demystifying AI, Research Papers, Agentic AI, LLMs, MCP, A2A, Deep Agents, Context Engineering"
>
  <div class="min-h-screen">
    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-border">
      <div class="absolute inset-0 bg-gradient-to-b from-green/[0.04] via-background to-background"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(63,185,80,0.06)_0%,transparent_60%)]"></div>

      <div class="relative container-main max-w-5xl pt-24 pb-12">
        <a href="/" class="inline-flex items-center gap-2 text-xs text-secondary hover:text-green transition-colors mb-10 font-mono">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
          cd ~/home
        </a>

        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span class="flex items-center gap-1.5 text-[10px] text-green font-mono bg-green/5 border border-green/20 px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>
                LIVE SERIES
              </span>
              <span class="text-[10px] text-secondary font-mono">Season 1</span>
            </div>

            <h1 class="text-3xl md:text-4xl font-bold text-foreground leading-tight mb-3">
              Demystifying AI <span class="text-green">in 5 Minutes</span>
            </h1>

            <p class="text-base text-secondary max-w-lg">
              One concept. Under five minutes. Three times a week. Built for engineers who ship.
            </p>
            <div class="mt-4">
              <ShareButtons title="Demystifying AI in 5 Minutes" url="/series/demystifying-ai" />
            </div>
          </div>

          <div class="flex items-center gap-6">
            <div class="text-center">
              <div class="text-xl font-bold text-foreground">3x</div>
              <div class="text-[9px] font-mono text-secondary uppercase">per week</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-foreground">5</div>
              <div class="text-[9px] font-mono text-secondary uppercase">min each</div>
            </div>
            <div class="text-center">
              <div class="text-xl font-bold text-foreground">150+</div>
              <div class="text-[9px] font-mono text-secondary uppercase">per year</div>
            </div>
          </div>
        </div>

        <!-- Schedule Strip -->
        <div class="flex items-center gap-2 mt-8">
          <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green/5 border border-green/20">
            <span class="w-2 h-2 rounded-full bg-green"></span>
            <span class="text-[10px] font-mono text-green">Mon: Hot Topic</span>
          </div>
          <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-500/5 border border-violet-500/20">
            <span class="w-2 h-2 rounded-full bg-violet-400"></span>
            <span class="text-[10px] font-mono text-violet-400">Wed: Research Paper</span>
          </div>
          <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-cyan/5 border border-cyan/20">
            <span class="w-2 h-2 rounded-full bg-cyan"></span>
            <span class="text-[10px] font-mono text-cyan">Sat: New Release</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Published Episodes - Slider -->
    {publishedEpisodes.length > 0 && (
      <section class="py-12 border-b border-border">
        <div class="container-main max-w-5xl">
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-3">
              <h2 class="text-lg font-semibold text-foreground">Published</h2>
              <span class="text-xs font-mono text-secondary">{publishedEpisodes.length} episode{publishedEpisodes.length > 1 ? 's' : ''}</span>
            </div>
            {publishedEpisodes.length > 2 && (
              <div class="flex items-center gap-2">
                <button id="pub-prev" class="w-8 h-8 rounded-lg border border-border bg-elevated flex items-center justify-center text-secondary hover:text-green hover:border-green/30 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button id="pub-next" class="w-8 h-8 rounded-lg border border-border bg-elevated flex items-center justify-center text-secondary hover:text-green hover:border-green/30 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
              </div>
            )}
          </div>

          <div class="relative">
            <div id="published-slider" class="flex gap-5 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide -mx-4 px-4">
              {publishedEpisodes.map((ep, idx) => {
                const cat = categoryConfig[ep.category];
                const isLatest = idx === 0;
                return (
                  <a href={`/series/demystifying-ai/${ep.slug}`} class={`snap-start shrink-0 w-[320px] md:w-[360px] group block rounded-xl border bg-elevated transition-all duration-300 overflow-hidden ${isLatest ? 'border-green/40 ring-1 ring-green/20' : 'border-border hover:border-green/30'}`}>
                    {/* Image Preview */}
                    <div class="relative h-44 overflow-hidden bg-gradient-to-br from-green/10 via-background to-violet-500/10">
                      {ep.image ? (
                        <img src={ep.image} alt={ep.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <div class="text-center">
                            <span class={`text-4xl font-bold ${cat.text} opacity-20`}>#{String(ep.number).padStart(2, '0')}</span>
                          </div>
                        </div>
                      )}
                      <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/30 to-transparent"></div>
                      <div class="absolute top-3 left-3 flex items-center gap-2">
                        <span class={`px-2 py-0.5 text-[9px] font-mono rounded ${cat.bg} ${cat.border} border ${cat.text} backdrop-blur-sm`}>{cat.label}</span>
                        {isLatest && (
                          <span class="px-2 py-0.5 text-[9px] font-mono rounded bg-green/20 border border-green/30 text-green backdrop-blur-sm flex items-center gap-1">
                            <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>Latest
                          </span>
                        )}
                      </div>
                      <div class="absolute bottom-3 left-4 right-4">
                        <span class="text-[10px] font-mono text-white/60">#{String(ep.number).padStart(2, '0')} &middot; {ep.day}, {ep.date}</span>
                      </div>
                    </div>

                    {/* Content */}
                    <div class="p-4">
                      <h3 class="text-sm font-semibold text-foreground group-hover:text-green transition-colors mb-2 line-clamp-2">{ep.title}</h3>
                      <p class="text-xs text-secondary line-clamp-2 mb-3">{ep.hook}</p>
                      <div class="flex items-center justify-between">
                        <span class="text-[10px] text-secondary">{ep.readTime}</span>
                        <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">
                          Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
            {publishedEpisodes.length > 2 && (
              <div class="absolute right-0 top-0 bottom-4 w-16 bg-gradient-to-l from-background to-transparent pointer-events-none"></div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Next Episode -->
    {nextEpisode && (
      <section class="py-12">
        <div class="container-main max-w-5xl">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-lg font-semibold text-foreground">Next Episode</h2>
            <div class="flex-1 h-px bg-border"></div>
            <span class="text-xs font-mono text-secondary">{nextEpisode.day}, {nextEpisode.date}</span>
          </div>

          <div class="relative rounded-2xl border border-green/20 bg-elevated overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-green via-green/60 to-transparent"></div>
            
            <div class="p-8 md:p-10">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-sm font-mono text-green font-bold">#{String(nextEpisode.number).padStart(2, '0')}</span>
                <span class="px-2.5 py-0.5 text-[10px] font-mono rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400">Upcoming</span>
                <span class="text-xs text-secondary ml-auto">{nextEpisode.readTime}</span>
              </div>

              <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-4">
                {nextEpisode.title}
              </h2>

              <p class="text-base text-secondary mb-6">
                {nextEpisode.hook}
              </p>

              <div class="flex items-center gap-4">
                <span class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green/10 border border-green/20 text-green text-sm font-medium">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Drops {nextEpisode.day}
                </span>
                <span class="flex items-center gap-1.5 text-[10px] font-mono text-green">
                  <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>
                  Up next
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Subscribe / Follow -->
    <section class="border-t border-border">
      <div class="container-main max-w-5xl py-12">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 p-6 rounded-xl border border-border bg-elevated">
          <div>
            <h3 class="text-base font-semibold text-foreground mb-1">Never miss an episode</h3>
            <p class="text-xs text-secondary">New episodes drop Mon, Wed, Sat. Follow for updates.</p>
          </div>
          <a href="https://www.linkedin.com/in/mohdimran-khan/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-green/10 border border-green/20 text-green text-sm font-medium hover:bg-green/20 transition-colors shrink-0">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            Follow on LinkedIn
          </a>
        </div>
      </div>
    </section>
  </div>

  <script is:inline>
    const slider = document.getElementById('published-slider');
    const prevBtn = document.getElementById('pub-prev');
    const nextBtn = document.getElementById('pub-next');
    const cardWidth = 380;

    prevBtn?.addEventListener('click', () => {
      slider?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });
    nextBtn?.addEventListener('click', () => {
      slider?.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
  </script>
</BaseLayout>
