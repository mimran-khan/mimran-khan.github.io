        <!-- Part 5: Position Sizing -->
        <section id="sizing">
          <div class="font-mono text-sm text-green mb-6">
            <span class="text-secondary">05 //</span> Compound Position Sizing
          </div>
          
          <p class="text-body text-secondary leading-relaxed mb-6">
            Fixed lot sizing leaves money on the table when you're winning and amplifies losses when you're not. DeltaForge uses <strong class="text-foreground">compound position sizing</strong> that scales with your equity curve, but throttles aggressively during drawdowns.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            <div class="diagram-node rounded-xl border border-green/20 p-5 bg-green/5 glow-green">
