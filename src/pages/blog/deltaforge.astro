                <rect x="118" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="132" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G1</text>
                <rect x="151" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="165" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G2</text>
                <rect x="184" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="198" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G3</text>
                <rect x="217" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="231" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G4</text>
                <rect x="250" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="264" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G5</text>
                <rect x="283" y="90" width="32" height="60" rx="4" fill="rgba(210,153,34,0.08)" stroke="rgba(210,153,34,0.5)" stroke-width="0.8"/><text x="299" y="124" text-anchor="middle" fill="rgb(210,153,34)" font-size="7" font-family="monospace">G5.5</text>
                <rect x="320" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="334" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G6</text>
                <rect x="353" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="367" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G7</text>
                <rect x="386" y="90" width="28" height="60" rx="4" fill="rgba(63,185,80,0.08)" stroke="rgba(63,185,80,0.5)" stroke-width="0.8"/><text x="400" y="124" text-anchor="middle" fill="rgb(63,185,80)" font-size="7" font-family="monospace">G8</text>

                <!-- Arrow through gates -->
                <line x1="65" y1="120" x2="85" y2="120" stroke="rgba(63,185,80,0.5)" stroke-width="1" stroke-dasharray="3,2" class="animate-dash"/>

