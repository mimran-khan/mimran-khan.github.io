                <tr><td class="px-3 py-2 text-xs text-foreground font-mono">4</td><td class="px-3 py-2 text-xs text-secondary">Consecutive losses &lt; 5</td><td class="px-3 py-2 text-xs text-red-400 font-mono font-bold">HALT</td></tr>
                <tr><td class="px-3 py-2 text-xs text-foreground font-mono">5</td><td class="px-3 py-2 text-xs text-secondary">Drawdown &lt; 35% from peak</td><td class="px-3 py-2 text-xs text-red-400 font-mono font-bold">HALT</td></tr>
