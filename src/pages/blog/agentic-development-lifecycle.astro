                    </g>
                    <!-- Bi-directional arrows between nodes -->
                    <line x1="155" y1="42" x2="175" y2="63" stroke="rgba(63,185,80,0.4)" stroke-width="1" stroke-dasharray="3,2" class="animate-dash"/>
