                  <div class="diagram-node w-40 py-2.5 rounded-lg bg-red-500/5 border border-red-500/20 text-center text-sm text-red-400 font-mono">Design</div>
                  <svg class="w-4 h-6" viewBox="0 0 16 24"><path d="M8 0 L8 20 M4 16 L8 22 L12 16" stroke="rgb(248,81,73)" stroke-width="1.5" fill="none" opacity="0.4"/></svg>
                  <div class="diagram-node w-40 py-2.5 rounded-lg bg-red-500/5 border border-red-500/20 text-center text-sm text-red-400 font-mono">Develop</div>
                  <svg class="w-4 h-6" viewBox="0 0 16 24"><path d="M8 0 L8 20 M4 16 L8 22 L12 16" stroke="rgb(248,81,73)" stroke-width="1.5" fill="none" opacity="0.4"/></svg>
                  <div class="diagram-node w-40 py-2.5 rounded-lg bg-red-500/5 border border-red-500/20 text-center text-sm text-red-400 font-mono">Test</div>
                  <svg class="w-4 h-6" viewBox="0 0 16 24"><path d="M8 0 L8 20 M4 16 L8 22 L12 16" stroke="rgb(248,81,73)" stroke-width="1.5" fill="none" opacity="0.4"/></svg>
                  <div class="diagram-node w-40 py-2.5 rounded-lg bg-red-500/5 border border-red-500/20 text-center text-sm text-red-400 font-mono">Deploy</div>
                </div>
                <p class="text-xs text-red-400/60 text-center mt-3 font-mono">Sequential gates, one-way flow</p>
              </div>

              <!-- ADLC Side -->
              <div class="relative">
                <p class="text-xs font-mono text-green text-center mb-4 uppercase tracking-wider">Agentic ADLC</p>
                <div class="flex justify-center">
