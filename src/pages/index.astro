        <div class="flex gap-2">
          {experiences.map((_, i) => (
            <button 
              class="exp-dot w-2 h-2 rounded-full bg-border transition-all duration-300"
              data-index={i}
              aria-label={`Go to slide ${i + 1}`}
            ></button>
          ))}
        </div>
        
        <button id="exp-next-btn" class="p-2 rounded-full border border-border hover:border-green hover:text-green transition-all" aria-label="Next">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
