---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import AchievementCard from '../components/AchievementCard.astro';
import EducationTimeline from '../components/EducationTimeline.astro';
import EventsCarousel from '../components/EventsCarousel.astro';
import { getCollection } from 'astro:content';

import iitk from '../assets/images/education/iitk.png';
import bits from '../assets/images/education/bits-pillani.png';
import vtu from '../assets/images/education/vtu.png';
import amrita from '../assets/images/education/amrita.png';

const experiences = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const achievements = (await getCollection('achievements')).sort((a, b) => a.data.order - b.data.order);

const stats = [
  { value: '6+', label: 'Years' },
  { value: '3', label: 'Patents' },
  { value: '7', label: 'Awards' },
  { value: '10+', label: 'AI Products' },
];

const skillGroups = [
  {
    category: 'Agentic AI',
    skills: ['Multi-Agent Systems', 'MCP Servers', 'A2A Protocol', 'LangGraph', 'CrewAI', 'AutoGen', 'Tool Orchestration']
  },
  {
    category: 'LLM Engineering', 
    skills: ['RAG', 'Fine-tuning', 'QLoRA', 'Prompt Engineering', 'LLM Evals', 'Vector DBs', 'Embeddings']
  },
  {
    category: 'ML & Deep Learning',
    skills: ['PyTorch', 'TensorFlow', 'Transformers', 'Diffusion Models', 'CNNs', 'RNNs']
  },
  {
    category: 'NLP & Speech',
    skills: ['NLP', 'ASR', 'TTS', 'Speech-to-Speech', 'Translation', 'Sentiment Analysis']
  },
  {
    category: 'Infrastructure',
    skills: ['Python', 'FastAPI', 'MLOps', 'Kubernetes', 'Docker', 'SQL']
  },
  {
    category: 'Automation',
    skills: ['RPA', 'Automation Anywhere', 'UiPath', 'Process Automation']
  }
];

const education = [
  {
    institution: 'Amrita Vishwa Vidyapeetham',
    degree: 'PhD (Ongoing)',
    field: 'AI & ML',
    year: 'Ongoing',
    logo: amrita,
  },
  {
    institution: 'IIT Kanpur',
    degree: 'Masters',
    field: 'AI & ML',
    year: '2025',
    logo: iitk,
  },
  {
    institution: 'BITS Pilani',
    degree: 'M.Tech',
    field: 'AI & ML',
    year: '2024',
    logo: bits,
  },
  {
    institution: 'VTU',
    degree: 'B.E.',
    field: 'Computer Science',
    year: '2019',
    logo: vtu,
  },
];
---

<BaseLayout 
  title="Home" 
  description="Imran Khan - Senior ML Engineer at Red Hat. Ex-Principal ML Engineer at Mercedes-Benz R&D. PhD Scholar, IIT Kanpur, BITS Pilani. Agentic AI, Multi-Agent Systems, RAG, LLMs."
>
  <Hero />
  
  <!-- Stats -->
  <section class="border-y border-border py-8">
    <div class="container-main">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map(({ value, label }) => (
          <div class="text-center">
            <p class="text-h1 font-mono text-green">{value}</p>
            <p class="text-small text-secondary uppercase tracking-wider">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section">
    <div class="container-main">
      <p class="section-heading">Tech Stack</p>
      <div class="space-y-6">
        {skillGroups.map((group) => (
          <div>
            <p class="text-small text-green font-mono mb-3">// {group.category}</p>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="px-3 py-1.5 rounded-lg bg-elevated border border-border hover:border-green/50 transition-all duration-300 cursor-default text-sm text-foreground">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Blog</p>
      
      <div class="space-y-4">

      <!-- Blog Post: Loop Engineering -->
      <a 
        href="/blog/loop-engineering" 
        class="group block bg-elevated border border-border rounded-lg overflow-hidden hover:border-violet-500/50 transition-all duration-300"
      >
        <div class="flex flex-col md:flex-row">
          <!-- Compact thumbnail -->
          <div class="md:w-72 lg:w-80 shrink-0 bg-gradient-to-br from-violet-500/10 via-background to-green/10 p-6 flex items-center justify-center border-b md:border-b-0 md:border-r border-border">
            <div class="text-center">
              <div class="relative inline-block">
                <svg width="80" height="80" viewBox="0 0 80 80" class="mx-auto">
                  <circle cx="40" cy="40" r="28" fill="none" stroke="rgba(139,92,246,0.3)" stroke-width="1.5" stroke-dasharray="4,6"/>
                  <path d="M40 12 A28 28 0 0 1 68 40" fill="none" stroke="rgba(63,185,80,0.7)" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M68 40 A28 28 0 0 1 40 68" fill="none" stroke="rgba(57,211,213,0.7)" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M40 68 A28 28 0 0 1 12 40" fill="none" stroke="rgba(139,92,246,0.7)" stroke-width="2.5" stroke-linecap="round"/>
                  <path d="M12 40 A28 28 0 0 1 40 12" fill="none" stroke="rgba(210,153,34,0.7)" stroke-width="2.5" stroke-linecap="round"/>
                  <polygon points="40,9 43,15 37,15" fill="rgba(63,185,80,0.8)"/>
                  <circle cx="40" cy="40" r="8" fill="rgba(63,185,80,0.1)" stroke="rgba(63,185,80,0.4)" stroke-width="1"/>
                  <text x="40" y="44" text-anchor="middle" fill="rgba(63,185,80,0.8)" font-size="8" font-family="monospace" font-weight="bold">&#8734;</text>
                </svg>
              </div>
              <div class="text-xs text-secondary mt-2 font-mono">Autonomous Loop</div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex-1 p-6">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 text-xs font-mono bg-violet-500/10 text-violet-400 rounded border border-violet-500/20">Opinion</span>
              <span class="text-small text-secondary">Jul 4, 2026</span>
              <span class="text-text-muted">|</span>
              <span class="text-small text-secondary">6 min read</span>
            </div>
            <h3 class="text-h2 text-foreground group-hover:text-violet-400 transition-colors mb-2">
              Loop Engineering: The Paradigm That Kills Prompt Engineering
            </h3>
            <p class="text-body text-secondary mb-4">
              You shouldn't be prompting your agents anymore. Design systems that prompt them for you. The biggest shift in developer workflow since CI/CD — and what it means for the agentic world.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Loop Engineering</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Agentic AI</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Workflow</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Systems Design</span>
            </div>
            <div class="flex items-center gap-4 text-small text-secondary">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                6 primitives
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                Strong opinions
              </span>
              <span class="hidden sm:flex items-center gap-1 ml-auto text-violet-400 group-hover:translate-x-1 transition-transform">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>

      <!-- Blog Post: DeltaForge -->
      <a 
        href="/blog/deltaforge" 
        class="group block bg-elevated border border-border rounded-lg overflow-hidden hover:border-green/50 transition-all duration-300"
      >
        <div class="flex flex-col md:flex-row">
          <!-- Compact thumbnail -->
          <div class="md:w-72 lg:w-80 shrink-0 bg-gradient-to-br from-green/10 via-background to-cyan/10 p-6 flex items-center justify-center border-b md:border-b-0 md:border-r border-border">
            <div class="text-center">
              <div class="font-mono text-green text-2xl font-bold mb-1">&#916;F</div>
              <div class="font-mono text-green text-sm font-bold">DeltaForge</div>
              <div class="text-xs text-secondary mt-2">Autonomous Trading</div>
              <div class="flex items-center justify-center gap-1 mt-3">
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-yellow-500/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
                <span class="w-2 h-2 rounded-full bg-green/60"></span>
              </div>
              <div class="text-[10px] text-secondary mt-1 font-mono">9 risk gates</div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex-1 p-6">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 text-xs font-mono bg-green/10 text-green rounded border border-green/20">New</span>
              <span class="text-small text-secondary">Jul 4, 2026</span>
              <span class="text-text-muted">|</span>
              <span class="text-small text-secondary">14 min read</span>
            </div>
            <h3 class="text-h2 text-foreground group-hover:text-green transition-colors mb-2">
              DeltaForge: Building an Autonomous Options Trading System
            </h3>
            <p class="text-body text-secondary mb-4">
              How I built an autonomous Nifty options trading system with multi-strategy signals, 9-gate risk management, compound sizing, and a kill switch. Same engine, same signals — backtest to production.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Trading Systems</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Options</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Risk Mgmt</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Python</span>
            </div>
            <div class="flex items-center gap-4 text-small text-secondary">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                5 strategies
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                9-gate risk
              </span>
              <span class="hidden sm:flex items-center gap-1 ml-auto text-green group-hover:translate-x-1 transition-transform">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>

      <!-- Blog Post: Agents All the Way Down -->
      <a 
        href="/blog/agents-all-the-way-down" 
        class="group block bg-elevated border border-border rounded-lg overflow-hidden hover:border-green/50 transition-all duration-300"
      >
        <div class="flex flex-col md:flex-row">
          <!-- Compact thumbnail -->
          <div class="md:w-72 lg:w-80 shrink-0 bg-gradient-to-br from-green/10 via-background to-cyan/10 p-6 flex items-center justify-center border-b md:border-b-0 md:border-r border-border">
            <div class="text-center">
              <div class="relative inline-block">
                <div class="w-12 h-12 rounded-full bg-green/10 border border-green/30 flex items-center justify-center mx-auto">
                  <span class="font-mono text-green text-sm font-bold">L1</span>
                </div>
                <div class="flex items-center justify-center gap-3 mt-2">
                  <div class="w-8 h-8 rounded-md bg-cyan/10 border border-cyan/30 flex items-center justify-center">
                    <span class="font-mono text-cyan text-[10px]">L2</span>
                  </div>
                  <div class="w-8 h-8 rounded-md bg-cyan/10 border border-cyan/30 flex items-center justify-center">
                    <span class="font-mono text-cyan text-[10px]">L2</span>
                  </div>
                  <div class="w-8 h-8 rounded-md bg-cyan/10 border border-cyan/30 flex items-center justify-center">
                    <span class="font-mono text-cyan text-[10px]">L2</span>
                  </div>
                </div>
              </div>
              <div class="text-xs text-secondary mt-3 font-mono">Agent Hierarchy</div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex-1 p-6">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 text-xs font-mono bg-green/10 text-green rounded border border-green/20">Deep Dive</span>
              <span class="text-small text-secondary">Apr 29, 2026</span>
              <span class="text-text-muted">|</span>
              <span class="text-small text-secondary">18 min read</span>
            </div>
            <h3 class="text-h2 text-foreground group-hover:text-green transition-colors mb-2">
              Agents All the Way Down: The Architecture Nobody Talks About
            </h3>
            <p class="text-body text-secondary mb-4">
              90% of devs use AI tools daily - but almost nobody understands how hierarchical agent swarms actually ship code. Inside the promotion loops, protocol wars, and failure modes.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Agentic AI</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Multi-Agent</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">MCP</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">A2A</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">LangGraph</span>
            </div>
            <div class="flex items-center gap-4 text-small text-secondary">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                8 sections
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                Code examples
              </span>
              <span class="hidden sm:flex items-center gap-1 ml-auto text-green group-hover:translate-x-1 transition-transform">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>

      <!-- Blog Post: Claude Code Source -->
      <a 
        href="https://mimran-khan.github.io/claude-code-source/" 
        target="_blank" 
        rel="noopener noreferrer"
        class="group block bg-elevated border border-border rounded-lg overflow-hidden hover:border-green/50 transition-all duration-300"
      >
        <div class="flex flex-col md:flex-row">
          <!-- Thumbnail -->
          <div class="md:w-72 lg:w-80 shrink-0 bg-gradient-to-br from-green/10 via-background to-cyan/10 p-6 flex items-center justify-center border-b md:border-b-0 md:border-r border-border">
            <div class="text-center">
              <div class="text-6xl mb-2">🔓</div>
              <div class="font-mono text-green text-lg font-bold">ClaudeCode</div>
              <div class="text-xs text-secondary mt-1">512K+ Lines Exposed</div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex-1 p-6">
            <div class="flex items-center gap-2 mb-2">
              <span class="px-2 py-0.5 text-xs font-mono bg-green/10 text-green rounded">Featured</span>
              <span class="text-small text-secondary">Mar 31, 2026</span>
            </div>
            <h3 class="text-h2 text-foreground group-hover:text-green transition-colors mb-2">
              Claude Code Leaked | 512K Lines of Anthropic's AI Agent Source Code Exposed
            </h3>
            <p class="text-body text-secondary mb-4">
              Deep dive analysis of the leaked Claude Code source - 512,000+ lines of TypeScript revealing how Anthropic built the most advanced AI coding assistant. Explore the agentic loop, 40+ tools, and architectural patterns.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Agentic AI</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Claude Code</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">Source Analysis</span>
              <span class="px-2 py-1 text-xs bg-background border border-border rounded">TypeScript</span>
            </div>
            <div class="flex items-center gap-4 text-small text-secondary">
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                10 min read
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                512K+ lines analyzed
              </span>
              <span class="hidden sm:flex items-center gap-1 ml-auto text-green group-hover:translate-x-1 transition-transform">
                Read article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                </svg>
              </span>
            </div>
          </div>
        </div>
      </a>

      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Experience</p>
      
      <div class="space-y-4">
        {experiences.map((exp) => (
          <ExperienceCard
            company={exp.data.company}
            role={exp.data.role}
            startDate={exp.data.startDate}
            endDate={exp.data.endDate}
            location={exp.data.location}
            highlights={exp.data.highlights}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Events & Speaking -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Events & Speaking</p>
      <EventsCarousel />
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Projects</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            techStack={project.data.techStack}
            link={project.data.link}
            github={project.data.github}
            featured={project.data.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Education</p>
      
      <EducationTimeline items={education} />
    </div>
  </section>

  <!-- Certifications -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Certifications</p>
      
      <div class="space-y-6">
        <!-- Cloud & AI Platforms -->
        <div>
          <p class="text-small text-green font-mono mb-3">// Cloud & AI Platforms</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Azure AI Engineer Associate - Microsoft</span>
            <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Azure AI Fundamentals - Microsoft</span>
            <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Generative AI Fundamentals - Google Cloud</span>
            <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">LLMs & Transformers - Google Cloud</span>
            <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Image Generation & Captioning - Google Cloud</span>
          </div>
        </div>

        <!-- Machine Learning & AI -->
        <div>
          <p class="text-small text-green font-mono mb-3">// Machine Learning & AI</p>
