---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EducationTimeline from '../components/EducationTimeline.astro';
import EventsCarousel from '../components/EventsCarousel.astro';
import { getCollection } from 'astro:content';

import iitk from '../assets/images/education/iitk.png';
import bits from '../assets/images/education/bits-pillani.png';
import vtu from '../assets/images/education/vtu.png';
import amrita from '../assets/images/education/amrita.png';

const experiences = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
const projects = (await getCollection('projects')).filter(p => p.data.featured).sort((a, b) => a.data.order - b.data.order);

const skillGroups = [
  {
    category: 'Agentic AI',
    skills: ['Multi-Agent Systems', 'MCP Servers', 'A2A Protocol', 'LangGraph', 'CrewAI', 'AutoGen', 'Tool Orchestration']
  },
  {
    category: 'LLM Engineering', 
    skills: ['RAG', 'Fine-tuning', 'QLoRA', 'Prompt Engineering', 'LLM Evals', 'Vector DBs', 'Embeddings']
  },
  {
    category: 'ML & Deep Learning',
    skills: ['PyTorch', 'TensorFlow', 'Transformers', 'Diffusion Models', 'CNNs', 'RNNs']
  },
  {
    category: 'NLP & Speech',
    skills: ['NLP', 'ASR', 'TTS', 'Speech-to-Speech', 'Translation', 'Sentiment Analysis']
  },
  {
    category: 'Infrastructure',
    skills: ['Python', 'FastAPI', 'MLOps', 'Kubernetes', 'Docker', 'SQL']
  }
];

const education = [
  {
    institution: 'Amrita Vishwa Vidyapeetham',
    degree: 'PhD (Ongoing)',
    field: 'AI & ML',
    year: 'Ongoing',
    logo: amrita,
    note: 'Part-time research alongside industry work',
  },
  {
    institution: 'IIT Kanpur',
    degree: 'Masters',
    field: 'AI & ML',
    year: '2025',
    logo: iitk,
    note: '',
  },
  {
    institution: 'BITS Pilani',
    degree: 'M.Tech',
    field: 'AI & ML',
    year: '2024',
    logo: bits,
    note: '',
  },
  {
    institution: 'VTU',
    degree: 'B.E.',
    field: 'Computer Science',
    year: '2019',
    logo: vtu,
    note: '',
  },
];
---

<BaseLayout 
  title="Home" 
  description="Imran Khan - Senior ML Engineer at Red Hat. Ex-Principal ML Engineer at Mercedes-Benz R&D. PhD Scholar, IIT Kanpur, BITS Pilani. Agentic AI, Multi-Agent Systems, RAG, LLMs."
>
  <Hero />
  
  <!-- Now Building - Spotlight -->
  <section class="border-y border-border py-8">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="https://mimran-khan.github.io/deltaforge/" target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 p-5 rounded-xl border border-border bg-elevated hover:border-green/50 transition-all">
          <div class="w-12 h-12 rounded-lg bg-green/10 border border-green/20 flex items-center justify-center shrink-0">
            <span class="font-mono text-green text-lg font-bold">&#916;F</span>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-sm font-semibold text-foreground group-hover:text-green transition-colors">DeltaForge</h3>
              <span class="flex items-center gap-1 text-[10px] text-green font-mono"><span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>LIVE</span>
            </div>
            <p class="text-xs text-secondary mb-2">Autonomous Nifty options trading engine with 5 strategies, 9 risk gates, and compound position sizing.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">Live since Jun 2026</span>
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">5 strategies</span>
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">9 risk gates</span>
            </div>
          </div>
        </a>
        <a href="https://github.com/redhat-data-and-ai" target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 p-5 rounded-xl border border-border bg-elevated hover:border-cyan/50 transition-all">
          <div class="w-12 h-12 rounded-lg bg-cyan/10 border border-cyan/20 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="text-sm font-semibold text-foreground group-hover:text-cyan transition-colors">AI Agent Platform</h3>
              <span class="text-[10px] text-cyan font-mono">@ Red Hat</span>
            </div>
            <p class="text-xs text-secondary mb-2">MCP servers, A2A protocol, and multi-agent orchestration. Open source tooling for building production-grade AI agents.</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">MCP</span>
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">A2A Protocol</span>
              <span class="px-1.5 py-0.5 text-[10px] bg-background border border-border rounded">Open Source</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Blog</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Blog: Loop Engineering -->
        <a href="/blog/loop-engineering" class="group block rounded-xl overflow-hidden border border-border hover:border-violet-500/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-loop-engineering.png" alt="Loop Engineering" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-violet-500/20 text-violet-300 rounded backdrop-blur-sm">Opinion</span>
                <span class="text-[10px] text-white/70">6 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-violet-300 transition-colors">
                Loop Engineering: The Paradigm That Kills Prompt Engineering
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Design systems that prompt your agents for you. The biggest shift in developer workflow since CI/CD.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Jul 4, 2026</span>
              <span class="text-[10px] text-violet-400 group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: DeltaForge -->
        <a href="/blog/deltaforge" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-deltaforge.jpg" alt="DeltaForge" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Build Log</span>
                <span class="text-[10px] text-white/70">14 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                DeltaForge: Building an Autonomous Options Trading System
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Multi-strategy signals, 9-gate risk management, compound sizing, and a kill switch. Backtest to production.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Jun 5, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: Agents All the Way Down -->
        <a href="/blog/agents-all-the-way-down" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-agents-all-the-way-down.png" alt="Agents All the Way Down" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Deep Dive</span>
                <span class="text-[10px] text-white/70">18 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                Agents All the Way Down: The Architecture Nobody Talks About
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">How hierarchical agent swarms actually ship code. Promotion loops, protocol wars, and failure modes.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Apr 29, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: Claude Code Source -->
        <a href="/blog/claude-code-source" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-claude-code-source.png" alt="Claude Code Source Exposed" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Featured</span>
                <span class="text-[10px] text-white/70">10 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                Claude Code Leaked | Anthropic's AI Agent Source Exposed
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Deep dive into Anthropic's most advanced AI coding assistant. The agentic loop, 40+ tools, and architectural patterns.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Mar 31, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Experience</p>
      
      <div class="space-y-4">
        {experiences.map((exp) => (
          <ExperienceCard
            company={exp.data.company}
            role={exp.data.role}
            startDate={exp.data.startDate}
            endDate={exp.data.endDate}
            location={exp.data.location}
            highlights={exp.data.highlights}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Tech Stack</p>
      <div class="space-y-6">
        {skillGroups.map((group) => (
          <div>
            <p class="text-small text-green font-mono mb-3">// {group.category}</p>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="px-3 py-1.5 rounded-lg bg-elevated border border-border hover:border-green/50 transition-all duration-300 cursor-default text-sm text-foreground">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events & Speaking -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Events & Speaking</p>
      <EventsCarousel />
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Projects</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {projects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            techStack={project.data.techStack}
            link={project.data.link}
            github={project.data.github}
            featured={project.data.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Education</p>
      
      <EducationTimeline items={education} />
    </div>
  </section>

  <!-- Credentials -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Credentials</p>
      
      <div class="space-y-8">
        <!-- Patents -->
        <div>
          <p class="text-small text-green font-mono mb-3">// Patents (3)</p>
          <div class="space-y-2">
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2025</span>
              <span class="text-foreground">Multimodal Sign Language Translation with CHGCMA</span>
              <span class="text-xs text-secondary hidden sm:inline">Mercedes-Benz R&D</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2024</span>
              <span class="text-foreground">Multimodal Generative AI for Service Personalization</span>
              <span class="text-xs text-secondary hidden sm:inline">MIT WPU</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2024</span>
              <span class="text-foreground">Cognitive Models for Enhanced UX & Design Creativity</span>
              <span class="text-xs text-secondary hidden sm:inline">MIT WPU</span>
            </div>
          </div>
        </div>

        <!-- Awards -->
        <div>
          <p class="text-small text-green font-mono mb-3">// Awards</p>
          <div class="space-y-2">
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2024</span>
              <span class="text-foreground">IT Innovation Award - SyncX</span>
              <span class="text-xs text-secondary hidden sm:inline">Mercedes-Benz R&D</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2023</span>
              <span class="text-foreground">Intrapreneurship Award - Meet.IA</span>
              <span class="text-xs text-secondary hidden sm:inline">Mercedes-Benz R&D</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2022</span>
              <span class="text-foreground">Silver Star - Pioneering Spirit</span>
              <span class="text-xs text-secondary hidden sm:inline">Mercedes-Benz R&D</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2022</span>
              <span class="text-foreground">Best Cognitive Solution Award</span>
              <span class="text-xs text-secondary hidden sm:inline">Amayztech</span>
            </div>
            <div class="flex items-center gap-3 text-sm">
              <span class="font-mono text-green shrink-0 w-12">2020</span>
              <span class="text-foreground">Top Employee of the Year</span>
              <span class="text-xs text-secondary hidden sm:inline">HGS</span>
            </div>
          </div>
        </div>

        <!-- Certifications -->
        <div>
          <p class="text-small text-green font-mono mb-4">// Certifications</p>
          <div class="space-y-4">
            <div>
              <p class="text-xs text-secondary font-mono mb-2 uppercase tracking-wider">AI & Machine Learning</p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Azure AI Engineer Associate - Microsoft</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Machine Learning Specialization - Stanford</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Generative AI Fundamentals - Google Cloud</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">LLMs & Transformers - Google Cloud</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">GANs - DeepLearning.AI</span>
              </div>
            </div>
            <div>
              <p class="text-xs text-secondary font-mono mb-2 uppercase tracking-wider">Engineering & DevOps</p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">DevSecOps Grey Belt - Mercedes-Benz</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">GitHub Professional Certificate</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Master RPA Professional - Automation Anywhere</span>
              </div>
            </div>
            <div>
              <p class="text-xs text-secondary font-mono mb-2 uppercase tracking-wider">Management & Process</p>
              <div class="flex flex-wrap gap-2">
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">SAFe 5 Advanced Scrum Master - Scaled Agile</span>
                <span class="px-3 py-1.5 bg-elevated border border-border rounded-lg text-small text-foreground">Six Sigma Black Belt - PMI</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section border-t border-border">
    <div class="container-main">
      <div class="max-w-lg">
        <p class="section-heading">Contact</p>
        
        <h2 class="text-h1 text-foreground mb-4">
          Let's work together
        </h2>
        
        <p class="text-body text-secondary mb-6">
          I'm open to discussing AI/ML consulting, autonomous agent systems, and enterprise AI deployments.
        </p>
        
        <div class="flex flex-wrap gap-3">
          <a href="mailto:mohammed_imran.khan@outlook.com" class="btn btn-primary">
            Send Email
          </a>
          <a 
            href="https://linkedin.com/in/mohdimran-khan"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
