---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EducationTimeline from '../components/EducationTimeline.astro';
import EventsCarousel from '../components/EventsCarousel.astro';
import { getCollection } from 'astro:content';

import iitk from '../assets/images/education/iitk.png';
import bits from '../assets/images/education/bits-pillani.png';
import vtu from '../assets/images/education/vtu.png';
import amrita from '../assets/images/education/amrita.png';

const experiences = (await getCollection('experience')).sort((a, b) => a.data.order - b.data.order);
const companyLogos: Record<string, { src: string; height: string; invert: boolean }> = {
  'Red Hat': { src: '/logos/redhat.png', height: 'h-16', invert: false },
  'Mercedes-Benz R&D': { src: '/logos/mercedes-benz.png', height: 'h-20', invert: true },
  'Amayztech LLC': { src: '/logos/amayztech.png', height: 'h-8', invert: true },
  'Hinduja Global Solutions': { src: '/logos/hgs.png', height: 'h-14', invert: true },
};
const projects = (await getCollection('projects')).filter(p => p.data.featured).sort((a, b) => a.data.order - b.data.order);

const skillGroups = [
  {
    category: 'Agentic AI',
    skills: ['Multi-Agent Systems', 'MCP Servers', 'A2A Protocol', 'LangGraph', 'CrewAI', 'AutoGen', 'Tool Orchestration']
  },
  {
    category: 'LLM Engineering', 
    skills: ['RAG', 'Fine-tuning', 'QLoRA', 'Prompt Engineering', 'LLM Evals', 'Vector DBs', 'Embeddings']
  },
  {
    category: 'ML & Deep Learning',
    skills: ['PyTorch', 'TensorFlow', 'Transformers', 'Diffusion Models', 'CNNs', 'RNNs']
  },
  {
    category: 'NLP & Speech',
    skills: ['NLP', 'ASR', 'TTS', 'Speech-to-Speech', 'Translation', 'Sentiment Analysis']
  },
  {
    category: 'Infrastructure',
    skills: ['Python', 'FastAPI', 'MLOps', 'Kubernetes', 'Docker', 'SQL']
  }
];

const education = [
  {
    institution: 'Amrita Vishwa Vidyapeetham',
    degree: 'PhD (Ongoing)',
    field: 'AI & ML',
    year: 'Ongoing',
    logo: amrita,
    note: 'Part-time research alongside industry work',
  },
  {
    institution: 'IIT Kanpur',
    degree: 'Masters',
    field: 'AI & ML',
    year: '2025',
    logo: iitk,
    note: '',
  },
  {
    institution: 'BITS Pilani',
    degree: 'M.Tech',
    field: 'AI & ML',
    year: '2024',
    logo: bits,
    note: '',
  },
  {
    institution: 'VTU',
    degree: 'B.E.',
    field: 'Computer Science',
    year: '2019',
    logo: vtu,
    note: '',
  },
];
---

<BaseLayout 
  title="Home" 
  description="Imran Khan - Senior ML Engineer at Red Hat. Ex-Principal ML Engineer at Mercedes-Benz R&D. PhD Scholar, IIT Kanpur, BITS Pilani. Agentic AI, Multi-Agent Systems, RAG, LLMs."
>
  <Hero />

  <!-- Series: Demystifying AI -->
  <section id="series" class="relative border-t border-border overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-green/[0.03] via-background to-violet-500/[0.03]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,rgba(63,185,80,0.05)_0%,transparent_50%)]"></div>

    <div class="relative container-main py-6 md:py-10">
      <div class="flex items-center justify-between mb-4 md:mb-6">
        <div>
          <div class="flex items-center gap-2 md:gap-3 mb-2">
            <div class="w-7 h-7 md:w-8 md:h-8 rounded-lg bg-green/10 border border-green/20 flex items-center justify-center shrink-0">
              <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <a href="/series/demystifying-ai" class="text-lg md:text-xl font-bold text-foreground hover:text-green transition-colors">Demystifying AI in 5 Minutes</a>
            <span class="flex items-center gap-1 text-[10px] text-green font-mono"><span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>LIVE</span>
          </div>
          <p class="text-xs md:text-sm text-secondary">Deep dives into cutting-edge AI. Research papers, hot topics, and new releases broken down for builders.</p>
        </div>
        <a href="/series/demystifying-ai" class="hidden md:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-green/10 border border-green/20 text-green text-xs font-mono hover:bg-green/20 transition-colors shrink-0">
          Full series <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>

      <!-- Schedule: mobile = compact inline, desktop = 7-col grid -->
      <div class="hidden md:grid grid-cols-7 gap-2 mb-6">
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-green/5 border border-green/10">
          <span class="text-[9px] font-mono text-secondary">MON</span>
          <span class="w-2 h-2 rounded-full bg-green"></span>
          <span class="text-[8px] font-mono text-green">HOT</span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-subtle/30 border border-border/50 opacity-40">
          <span class="text-[9px] font-mono text-secondary">TUE</span>
          <span class="w-1.5 h-1.5 rounded-full bg-border"></span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-violet-500/5 border border-violet-500/10">
          <span class="text-[9px] font-mono text-secondary">WED</span>
          <span class="w-2 h-2 rounded-full bg-violet-400"></span>
          <span class="text-[8px] font-mono text-violet-400">PAPER</span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-subtle/30 border border-border/50 opacity-40">
          <span class="text-[9px] font-mono text-secondary">THU</span>
          <span class="w-1.5 h-1.5 rounded-full bg-border"></span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-subtle/30 border border-border/50 opacity-40">
          <span class="text-[9px] font-mono text-secondary">FRI</span>
          <span class="w-1.5 h-1.5 rounded-full bg-border"></span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-cyan/5 border border-cyan/10">
          <span class="text-[9px] font-mono text-secondary">SAT</span>
          <span class="w-2 h-2 rounded-full bg-cyan"></span>
          <span class="text-[8px] font-mono text-cyan">RELEASE</span>
        </div>
        <div class="flex flex-col items-center gap-1 px-2 py-2 rounded-lg bg-subtle/30 border border-border/50 opacity-40">
          <span class="text-[9px] font-mono text-secondary">SUN</span>
          <span class="w-1.5 h-1.5 rounded-full bg-border"></span>
        </div>
      </div>
      <div class="flex md:hidden items-center gap-2 mb-4 overflow-x-auto scrollbar-hide">
        <div class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-full bg-green/5 border border-green/10 shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-green"></span>
          <span class="text-[9px] font-mono text-green">Mon</span>
        </div>
        <div class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-full bg-violet-500/5 border border-violet-500/10 shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-violet-400"></span>
          <span class="text-[9px] font-mono text-violet-400">Wed</span>
        </div>
        <div class="flex items-center gap-1.5 px-2.5 py-1.5 rounded-full bg-cyan/5 border border-cyan/10 shrink-0">
          <span class="w-1.5 h-1.5 rounded-full bg-cyan"></span>
          <span class="text-[9px] font-mono text-cyan">Sat</span>
        </div>
      </div>

      <!-- Published -->
      <div class="mb-4 md:mb-6">
        <div class="flex items-center gap-3 mb-3 md:mb-4">
          <p class="text-xs font-mono text-green">// Published</p>
          <div class="flex-1 h-px bg-border"></div>
          <span class="text-[10px] font-mono text-secondary">2 episodes</span>
        </div>

        <div id="series-published-track" class="flex gap-3 md:gap-4 overflow-x-auto pb-2 snap-x snap-mandatory scrollbar-hide">
          <a href="/series/demystifying-ai/agent-harness-grep" class="snap-start shrink-0 w-[85vw] md:w-[calc(50%-0.5rem)] group relative rounded-xl border border-border bg-elevated overflow-hidden hover:border-violet-500/40 transition-all duration-300">
            <div class="absolute top-0 left-0 w-1 h-full bg-violet-500/60 rounded-l-xl"></div>
            <div class="p-5 pl-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-mono text-violet-400 font-bold">#02</span>
                <span class="px-2 py-0.5 text-[9px] font-mono bg-violet-500/10 border border-violet-500/20 text-violet-400 rounded">Research Paper</span>
                <span class="px-2 py-0.5 text-[9px] font-mono bg-green/20 border border-green/30 text-green rounded flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>Latest</span>
                <span class="text-[10px] text-secondary ml-auto">Wednesday, Jul 8</span>
              </div>
              <h3 class="text-base font-semibold text-foreground group-hover:text-violet-400 transition-colors mb-2">
                Is Grep All You Need? Agent Harness Paper
              </h3>
              <p class="text-xs text-secondary line-clamp-2">Grep beats vector search inside AI agents. The harness matters more than retrieval. Breaking down arxiv 2605.15184.</p>
              <div class="flex items-center gap-2 mt-3">
                <span class="text-[10px] text-secondary">5 min read</span>
                <span class="text-[10px] text-violet-400 group-hover:translate-x-1 transition-transform flex items-center gap-1 ml-auto">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
              </div>
            </div>
          </a>
          <a href="/series/demystifying-ai/deep-agents" class="snap-start shrink-0 w-[85vw] md:w-[calc(50%-0.5rem)] group relative rounded-xl border border-border bg-elevated overflow-hidden hover:border-green/40 transition-all duration-300">
            <div class="absolute top-0 left-0 w-1 h-full bg-green/60 rounded-l-xl"></div>
            <div class="p-5 pl-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-mono text-green font-bold">#01</span>
                <span class="px-2 py-0.5 text-[9px] font-mono bg-green/10 border border-green/20 text-green rounded">Hot Topic</span>
                <span class="text-[10px] text-secondary ml-auto">Monday, Jul 6</span>
              </div>
              <h3 class="text-base font-semibold text-foreground group-hover:text-green transition-colors mb-2">
                What are LangChain Deep Agents?
              </h3>
              <p class="text-xs text-secondary line-clamp-2">LangChain shipped something that makes CrewAI and AutoGen look like toys. Nobody noticed. Here's the 3-layer stack that changes everything.</p>
              <div class="flex items-center gap-2 mt-3">
                <span class="text-[10px] text-secondary">5 min read</span>
                <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1 ml-auto">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
              </div>
            </div>
          </a>
        </div>
      </div>

      <!-- Up Next -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <p class="text-xs font-mono text-cyan">// Up Next</p>
          <div class="flex-1 h-px bg-border"></div>
          <span class="text-[10px] font-mono text-secondary">Saturday, Jul 11</span>
        </div>

        <div class="group relative rounded-xl border border-dashed border-cyan/30 bg-elevated/50 overflow-hidden cursor-default">
          <div class="absolute top-0 left-0 w-1 h-full bg-cyan/30 rounded-l-xl"></div>
          <div class="p-5 pl-6">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-xs font-mono text-cyan font-bold">#03</span>
              <span class="px-2 py-0.5 text-[9px] font-mono bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 rounded">Upcoming</span>
            </div>
            <h3 class="text-base font-semibold text-foreground/70 mb-2">
              LongCat-2.0: Open-Source 1M Context That Beats GPT-5.5
            </h3>
            <p class="text-xs text-secondary/70 line-clamp-2">Meituan just dropped a 1.6T parameter model with 1M token context. MIT licensed. It outperforms GPT-5.5 on SWE-bench Pro.</p>
            <div class="flex items-center gap-2 mt-3">
              <span class="text-[10px] text-secondary">5 min read</span>
              <span class="text-[10px] text-cyan/60 flex items-center gap-1 ml-auto">Drops Sat</span>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-between mt-4 md:mt-6">
        <div class="flex items-center gap-2 md:gap-4 text-[9px] md:text-[10px] text-secondary font-mono flex-wrap">
          <span>3x/week</span>
          <span class="text-border">|</span>
          <span>Mon &middot; Wed &middot; Sat</span>
          <span class="text-border hidden md:inline">|</span>
          <span class="hidden md:inline">150+ episodes/year</span>
        </div>
        <a href="/series/demystifying-ai" class="md:hidden text-xs text-green flex items-center gap-1 font-mono shrink-0">
          All <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section id="blog" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Blog</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Blog: Loop Engineering -->
        <a href="/blog/loop-engineering" class="group block rounded-xl overflow-hidden border border-border hover:border-violet-500/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-loop-engineering.png" alt="Loop Engineering" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-violet-500/20 text-violet-300 rounded backdrop-blur-sm">Opinion</span>
                <span class="text-[10px] text-white/70">6 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-violet-300 transition-colors">
                Loop Engineering: The Paradigm That Kills Prompt Engineering
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Design systems that prompt your agents for you. The biggest shift in developer workflow since CI/CD.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Jul 4, 2026</span>
              <span class="text-[10px] text-violet-400 group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: DeltaForge -->
        <a href="/blog/deltaforge" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-deltaforge.jpg" alt="DeltaForge" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Build Log</span>
                <span class="text-[10px] text-white/70">14 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                DeltaForge: Building an Autonomous Options Trading System
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Multi-strategy signals, 9-gate risk management, compound sizing, and a kill switch. Backtest to production.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Jun 5, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: Agents All the Way Down -->
        <a href="/blog/agents-all-the-way-down" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-agents-all-the-way-down.png" alt="Agents All the Way Down" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Deep Dive</span>
                <span class="text-[10px] text-white/70">18 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                Agents All the Way Down: The Architecture Nobody Talks About
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">How hierarchical agent swarms actually ship code. Promotion loops, protocol wars, and failure modes.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Apr 29, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

        <!-- Blog: Claude Code Source -->
        <a href="/blog/claude-code-source" class="group block rounded-xl overflow-hidden border border-border hover:border-green/50 transition-all duration-300">
          <div class="relative h-40 overflow-hidden">
            <img src="/og-blog-claude-code-source.png" alt="Claude Code Source Exposed" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#0d1117] via-[#0d1117]/40 to-transparent"></div>
            <div class="absolute bottom-3 left-4 right-4">
              <div class="flex items-center gap-2 mb-1">
                <span class="px-2 py-0.5 text-[10px] font-mono bg-green/20 text-green rounded backdrop-blur-sm">Featured</span>
                <span class="text-[10px] text-white/70">10 min read</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-green transition-colors">
                Claude Code Leaked | Anthropic's AI Agent Source Exposed
              </h3>
            </div>
          </div>
          <div class="bg-elevated p-4">
            <p class="text-xs text-secondary line-clamp-2">Deep dive into Anthropic's most advanced AI coding assistant. The agentic loop, 40+ tools, and architectural patterns.</p>
            <div class="flex items-center justify-between mt-3">
              <span class="text-[10px] text-secondary">Mar 31, 2026</span>
              <span class="text-[10px] text-green group-hover:translate-x-1 transition-transform flex items-center gap-1">Read <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Events & Speaking -->
  <section class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Events & Speaking</p>
      <EventsCarousel />
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section border-t border-border">
    <div class="container-main">
      <p class="section-heading">Experience</p>
    </div>

    <div class="exp-carousel container-main">
      <div class="relative overflow-hidden rounded-xl border border-border bg-elevated" id="exp-container">
        {experiences.map((exp, i) => {
          const isPresent = !exp.data.endDate;
          const dateRange = exp.data.endDate ? `${exp.data.startDate} - ${exp.data.endDate}` : `${exp.data.startDate} - Present`;
          const logo = companyLogos[exp.data.company];
          return (
            <div class={`exp-slide ${i === 0 ? '' : 'hidden'}`} data-slide={i}>
              <div class="relative h-32 overflow-hidden bg-gradient-to-br from-green/10 via-background to-cyan/5">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(63,185,80,0.12)_0%,transparent_60%)]"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>

                {logo && (
                  <div class="absolute top-0 bottom-0 right-6 flex items-center justify-center">
                    <img src={logo.src} alt={exp.data.company} class={`${logo.height} w-auto object-contain`} style={logo.invert ? "filter: brightness(0) invert(1); opacity: 0.85;" : "opacity: 0.85;"} />
                  </div>
                )}

                <div class="absolute bottom-0 left-0 right-0 p-5">
                  <h3 class="text-lg font-semibold text-foreground">{exp.data.role}</h3>
                  <p class="text-sm text-secondary">{exp.data.company}</p>
                  <div class="flex items-center gap-3 mt-2">
                    <span class="text-xs text-secondary">{exp.data.location}</span>
                    <span class="text-border">|</span>
                    <span class="px-2.5 py-0.5 rounded-full bg-green/10 text-xs text-green font-medium flex items-center gap-1.5">
                      {isPresent && <span class="w-1.5 h-1.5 rounded-full bg-green animate-pulse"></span>}
                      {dateRange}
                    </span>
